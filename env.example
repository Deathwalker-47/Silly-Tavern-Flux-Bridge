# Flux LoRA Bridge configuration
# Copy this file to .env and fill only the values you intend to use.
# Never commit your real .env file.

# ---- Core service ----
BRIDGE_PORT=7861
LORA_DICT_PATH=master_lora_dict.json
ENABLE_SUMMARIZATION=true
SUMMARY_MAX_LENGTH=300

# ---- Runware (primary image provider) ----
RUNWARE_API_KEY=
RUNWARE_ENDPOINT=https://api.runware.ai/v1
RUNWARE_MODEL=runware:101@1

# ---- Wavespeed ----
WAVESPEED_API_KEY=
MAXLORAS_WAVESPEED=4

# ---- FAL ----
FAL_API_KEY=
MAXLORAS_FAL=3

# ---- Together AI ----
TOGETHER_API_KEY=
MAXLORAS_TOGETHER=2

# ---- Debugging ----
# Set to true to log every streamed token (verbose, for debugging only)
DEBUG_STREAM_TAP=false
